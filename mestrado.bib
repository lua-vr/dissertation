@article{behrischDynamicalSystemsCategories2017,
  title = {Dynamical {{Systems}} in {{Categories}}},
  author = {Behrisch, Mike and Kerkhoff, Sebastian and Pöschel, Reinhard and Schneider, Friedrich Martin and Siegmund, Stefan},
  date = {2017-02-01},
  journaltitle = {Applied Categorical Structures},
  shortjournal = {Appl Categor Struct},
  volume = {25},
  number = {1},
  pages = {29--57},
  issn = {1572-9095},
  doi = {10.1007/s10485-015-9409-8},
  url = {https://doi.org/10.1007/s10485-015-9409-8},
  urldate = {2024-06-24},
  abstract = {In this article we establish a bridge between dynamical systems, including topological and measurable dynamical systems as well as continuous skew product flows and nonautonomous dynamical systems; and coalgebras in categories having all finite products. We introduce a straightforward unifying definition of abstract dynamical system on finite product categories. Furthermore, we prove that such systems are in a unique correspondence with monadic algebras whose signature functor takes products with the time space. We discuss that the categories of topological spaces, metrisable and uniformisable spaces have exponential objects w.r.t. locally compact Hausdorff, strongly σ-compact or arbitrary time spaces as exponents, respectively. Exploiting the adjunction between taking products and exponential objects, we demonstrate a one-to-one correspondence between monadic algebras (given by dynamical systems) for the left-adjoint functor and comonadic coalgebras for the other. This, finally, provides a new, alternative perspective on dynamical systems.},
  langid = {english},
  keywords = {18C15,18D15,68Q65,Coalgebra,Dynamical system,Finite product category,Primary 37B99,Secondary 37B55,Theory of systems},
  file = {/home/lucas/dados/biblioteca/kobo/zotfiles/mestrado/Behrisch et al. - 2017 - Dynamical Systems in Categories.pdf}
}

